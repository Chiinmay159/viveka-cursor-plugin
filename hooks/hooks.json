{
  "hooks": {
    "sessionStart": [
      {
        "command": "VIVEKA_HOOK_EVENT=sessionStart bash scripts/viveka-hook.sh",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "VIVEKA_HOOK_EVENT=preToolUse bash scripts/viveka-hook.sh",
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "VIVEKA_HOOK_EVENT=beforeShellExecution bash scripts/viveka-hook.sh",
        "timeout": 5
      }
    ],
    "afterFileEdit": [
      {
        "command": "VIVEKA_HOOK_EVENT=afterFileEdit bash scripts/viveka-hook.sh",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "VIVEKA_HOOK_EVENT=stop bash scripts/viveka-hook.sh",
        "timeout": 5
      }
    ]
  }
}
